{
  "mcpServers": {
    "snowflake-readonly": {
      "command": "python",
      "args": ["/path/to/snowflake_mcp_server/main.py"],
      "env": {
        "SNOWFLAKE_ACCOUNT": "${SNOWFLAKE_ACCOUNT",
        "SNOWFLAKE_USERNAME": "${SNOWFLAKE_USERNAME}",
        "SNOWFLAKE_WAREHOUSE": "${SNOWFLAKE_WAREHOUSE}",
        "SNOWFLAKE_PAT": "${SNOWFLAKE_PAT}"
      }
    }
  }
}