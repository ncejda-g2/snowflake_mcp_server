"""Tests for server/tools/save_to_csv.py module."""

import csv
import tempfile
from pathlib import Path
from unittest.mock import Mock, patch

import pytest

from server.tools.save_to_csv import save_last_query_to_csv


class TestSaveLastQueryToCsv:
    """Test save_last_query_to_csv function."""

    @patch("server.tools.save_to_csv.get_connection")
    def test_save_success(self, mock_get_connection):
        """Test successful CSV export."""
        # Setup mock connection with query result
        mock_conn = Mock()
        mock_conn.get_last_query_result.return_value = {
            "query": "SELECT * FROM test_table",
            "data": [(1, "Alice", 25), (2, "Bob", 30)],
            "columns": ["id", "name", "age"]
        }
        mock_get_connection.return_value = mock_conn

        with tempfile.TemporaryDirectory() as tmpdir:
            csv_path = Path(tmpdir) / "test.csv"

            result = save_last_query_to_csv(
                file_path=str(csv_path),
                export_sql=True
            )

            assert result["success"] is True
            assert result["csv_file"] == str(csv_path)
            assert result["row_count"] == 2
            assert csv_path.exists()

            # Verify CSV content
            with open(csv_path) as f:
                reader = csv.reader(f)
                rows = list(reader)
                assert rows[0] == ["id", "name", "age"]  # Headers
                assert rows[1] == ["1", "Alice", "25"]
                assert rows[2] == ["2", "Bob", "30"]

            # Verify SQL file was created
            sql_path = csv_path.with_suffix(".sql")
            assert sql_path.exists()
            with open(sql_path) as f:
                sql_content = f.read()
                assert "SELECT * FROM test_table" in sql_content

    @patch("server.tools.save_to_csv.get_connection")
    def test_save_without_sql_export(self, mock_get_connection):
        """Test CSV export without SQL file."""
        mock_conn = Mock()
        mock_conn.get_last_query_result.return_value = {
            "query": "SELECT 1",
            "data": [(1,)],
            "columns": ["col"]
        }
        mock_get_connection.return_value = mock_conn

        with tempfile.TemporaryDirectory() as tmpdir:
            csv_path = Path(tmpdir) / "test.csv"

            result = save_last_query_to_csv(
                file_path=str(csv_path),
                export_sql=False
            )

            assert result["success"] is True
            assert csv_path.exists()

            # SQL file should not exist
            sql_path = csv_path.with_suffix(".sql")
            assert not sql_path.exists()

    @patch("server.tools.save_to_csv.get_connection")
    def test_save_no_last_query(self, mock_get_connection):
        """Test saving when no query has been executed."""
        mock_conn = Mock()
        mock_conn.get_last_query_result.return_value = None
        mock_get_connection.return_value = mock_conn

        result = save_last_query_to_csv(file_path="/tmp/test.csv")

        assert result["success"] is False
        assert "No query results" in result["error"]

    @patch("server.tools.save_to_csv.get_connection")
    def test_save_empty_results(self, mock_get_connection):
        """Test saving empty query results."""
        mock_conn = Mock()
        mock_conn.get_last_query_result.return_value = {
            "query": "SELECT * FROM empty_table",
            "data": [],
            "columns": ["id", "name"]
        }
        mock_get_connection.return_value = mock_conn

        with tempfile.TemporaryDirectory() as tmpdir:
            csv_path = Path(tmpdir) / "empty.csv"

            result = save_last_query_to_csv(file_path=str(csv_path))

            assert result["success"] is True
            assert result["row_count"] == 0
            assert csv_path.exists()

            # Verify only headers are written
            with open(csv_path) as f:
                reader = csv.reader(f)
                rows = list(reader)
                assert len(rows) == 1  # Only headers
                assert rows[0] == ["id", "name"]

    @patch("server.tools.save_to_csv.get_connection")
    def test_save_with_null_values(self, mock_get_connection):
        """Test saving data with NULL values."""
        mock_conn = Mock()
        mock_conn.get_last_query_result.return_value = {
            "query": "SELECT * FROM test",
            "data": [(1, None, "test"), (2, "value", None)],
            "columns": ["id", "col1", "col2"]
        }
        mock_get_connection.return_value = mock_conn

        with tempfile.TemporaryDirectory() as tmpdir:
            csv_path = Path(tmpdir) / "nulls.csv"

            result = save_last_query_to_csv(file_path=str(csv_path))

            assert result["success"] is True

            with open(csv_path) as f:
                reader = csv.reader(f)
                rows = list(reader)
                assert rows[1] == ["1", "", "test"]  # None becomes empty string
                assert rows[2] == ["2", "value", ""]

    @patch("server.tools.save_to_csv.get_connection")
    def test_save_file_write_error(self, mock_get_connection):
        """Test handling file write errors."""
        mock_conn = Mock()
        mock_conn.get_last_query_result.return_value = {
            "query": "SELECT 1",
            "data": [(1,)],
            "columns": ["col"]
        }
        mock_get_connection.return_value = mock_conn

        # Try to write to a non-existent directory
        result = save_last_query_to_csv(
            file_path="/nonexistent/directory/test.csv"
        )

        assert result["success"] is False
        assert "Error" in result["error"]

    @patch("server.tools.save_to_csv.get_connection")
    def test_save_creates_parent_directories(self, mock_get_connection):
        """Test that parent directories are created if needed."""
        mock_conn = Mock()
        mock_conn.get_last_query_result.return_value = {
            "query": "SELECT 1",
            "data": [(1,)],
            "columns": ["col"]
        }
        mock_get_connection.return_value = mock_conn

        with tempfile.TemporaryDirectory() as tmpdir:
            csv_path = Path(tmpdir) / "nested" / "dir" / "test.csv"

            result = save_last_query_to_csv(file_path=str(csv_path))

            assert result["success"] is True
            assert csv_path.exists()
            assert csv_path.parent.exists()