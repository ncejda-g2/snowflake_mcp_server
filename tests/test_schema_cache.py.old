"""Tests for server/schema_cache.py module."""

import json
import tempfile
from datetime import datetime, timedelta
from pathlib import Path
from unittest.mock import MagicMock, Mock, patch

import pytest

from server.schema_cache import ColumnInfo, SchemaCache, TableInfo


class TestColumnInfo:
    """Test ColumnInfo dataclass."""

    def test_column_info_creation(self):
        """Test creating a ColumnInfo instance."""
        col = ColumnInfo(
            name="user_id",
            data_type="NUMBER",
            is_nullable=False,
            ordinal_position=1,
            comment="User identifier",
            default_value="0",
            is_primary_key=True
        )

        assert col.name == "user_id"
        assert col.data_type == "NUMBER"
        assert col.is_nullable is False
        assert col.ordinal_position == 1
        assert col.comment == "User identifier"
        assert col.default_value == "0"
        assert col.is_primary_key is True

    def test_column_info_minimal(self):
        """Test creating a ColumnInfo with minimal fields."""
        col = ColumnInfo(
            name="email",
            data_type="VARCHAR",
            is_nullable=True,
            ordinal_position=2
        )

        assert col.name == "email"
        assert col.data_type == "VARCHAR"
        assert col.is_nullable is True
        assert col.ordinal_position == 2
        assert col.comment is None
        assert col.default_value is None
        assert col.is_primary_key is False


class TestTableInfo:
    """Test TableInfo dataclass."""

    def test_table_info_creation(self):
        """Test creating a TableInfo instance."""
        columns = [
            ColumnInfo("id", "NUMBER", False, 1, is_primary_key=True),
            ColumnInfo("name", "VARCHAR", True, 2),
        ]

        table = TableInfo(
            database="TEST_DB",
            schema="PUBLIC",
            table_name="USERS",
            table_type="TABLE",
            columns=columns,
            row_count=1000,
            bytes=50000,
            comment="User table",
            last_altered="2024-01-01T00:00:00Z"
        )

        assert table.database == "TEST_DB"
        assert table.schema == "PUBLIC"
        assert table.table_name == "USERS"
        assert table.table_type == "TABLE"
        assert len(table.columns) == 2
        assert table.row_count == 1000
        assert table.bytes == 50000
        assert table.comment == "User table"
        assert table.last_altered == "2024-01-01T00:00:00Z"

    def test_table_info_full_name(self):
        """Test the full_name property."""
        table = TableInfo(
            database="TEST_DB",
            schema="PUBLIC",
            table_name="USERS",
            table_type="TABLE",
            columns=[]
        )

        assert table.full_name == "TEST_DB.PUBLIC.USERS"

    def test_table_info_to_dict(self):
        """Test converting TableInfo to dictionary."""
        columns = [
            ColumnInfo("id", "NUMBER", False, 1),
            ColumnInfo("name", "VARCHAR", True, 2),
        ]

        table = TableInfo(
            database="TEST_DB",
            schema="PUBLIC",
            table_name="USERS",
            table_type="TABLE",
            columns=columns,
            row_count=100
        )

        result = table.to_dict()

        assert result["database"] == "TEST_DB"
        assert result["schema"] == "PUBLIC"
        assert result["table_name"] == "USERS"
        assert result["table_type"] == "TABLE"
        assert len(result["columns"]) == 2
        assert result["columns"][0]["name"] == "id"
        assert result["row_count"] == 100
        assert result["bytes"] is None

    def test_table_info_from_dict(self):
        """Test creating TableInfo from dictionary."""
        data = {
            "database": "TEST_DB",
            "schema": "PUBLIC",
            "table_name": "USERS",
            "table_type": "TABLE",
            "columns": [
                {"name": "id", "data_type": "NUMBER", "is_nullable": False, "ordinal_position": 1},
                {"name": "name", "data_type": "VARCHAR", "is_nullable": True, "ordinal_position": 2},
            ],
            "row_count": 100,
            "bytes": 5000,
            "comment": "Test table",
        }

        table = TableInfo.from_dict(data)

        assert table.database == "TEST_DB"
        assert table.schema == "PUBLIC"
        assert table.table_name == "USERS"
        assert len(table.columns) == 2
        assert table.columns[0].name == "id"
        assert table.row_count == 100

    def test_table_info_from_dict_missing_optional_fields(self):
        """Test creating TableInfo from dictionary with missing optional fields."""
        data = {
            "database": "TEST_DB",
            "schema": "PUBLIC",
            "table_name": "USERS",
            "columns": []
        }

        table = TableInfo.from_dict(data)

        assert table.database == "TEST_DB"
        assert table.table_type == "TABLE"  # Default value
        assert table.row_count is None
        assert table.bytes is None
        assert table.comment is None


class TestSchemaCache:
    """Test SchemaCache class."""

    @pytest.fixture
    def temp_cache_dir(self):
        """Create a temporary directory for cache."""
        with tempfile.TemporaryDirectory() as tmpdir:
            yield Path(tmpdir)

    @pytest.fixture
    def cache(self, temp_cache_dir):
        """Create a SchemaCache instance with temporary directory."""
        return SchemaCache(ttl_days=5, cache_dir=temp_cache_dir)

    def test_schema_cache_initialization(self, temp_cache_dir):
        """Test SchemaCache initialization."""
        cache = SchemaCache(ttl_days=7, cache_dir=temp_cache_dir)

        assert cache.ttl_days == 7
        assert cache.cache_dir == temp_cache_dir
        assert cache.cache_file == temp_cache_dir / "schema_cache.json"
        assert cache.checkpoint_dir == temp_cache_dir / "checkpoints"
        assert cache.error_log_file == temp_cache_dir / "refresh_errors.json"
        assert cache.tables == {}
        assert cache.databases == set()
        assert cache.last_refresh is None
        assert cache.refresh_in_progress is False

    def test_schema_cache_creates_directories(self):
        """Test that SchemaCache creates necessary directories."""
        with tempfile.TemporaryDirectory() as tmpdir:
            cache_dir = Path(tmpdir) / "nonexistent" / "nested"
            cache = SchemaCache(cache_dir=cache_dir)

            assert cache_dir.exists()
            assert cache.checkpoint_dir.exists()

    def test_is_expired_no_refresh(self, cache):
        """Test is_expired when no refresh has occurred."""
        assert cache.is_expired() is True

    def test_is_expired_recent_refresh(self, cache):
        """Test is_expired with recent refresh."""
        cache.last_refresh = datetime.now()
        assert cache.is_expired() is False

    def test_is_expired_old_refresh(self, cache):
        """Test is_expired with old refresh."""
        cache.last_refresh = datetime.now() - timedelta(days=10)
        assert cache.is_expired() is True

    def test_add_table(self, cache):
        """Test adding a table to cache."""
        table = TableInfo(
            database="TEST_DB",
            schema="PUBLIC",
            table_name="USERS",
            table_type="TABLE",
            columns=[]
        )

        cache.add_table(table)

        assert "TEST_DB.PUBLIC.USERS" in cache.tables
        assert cache.tables["TEST_DB.PUBLIC.USERS"] == table
        assert "TEST_DB" in cache.databases

    def test_get_table(self, cache):
        """Test getting a table from cache."""
        table = TableInfo(
            database="TEST_DB",
            schema="PUBLIC",
            table_name="USERS",
            table_type="TABLE",
            columns=[]
        )
        cache.add_table(table)

        result = cache.get_table("TEST_DB", "PUBLIC", "USERS")
        assert result == table

    def test_get_table_not_found(self, cache):
        """Test getting a non-existent table."""
        result = cache.get_table("TEST_DB", "PUBLIC", "NONEXISTENT")
        assert result is None

    def test_get_tables_in_schema(self, cache):
        """Test getting all tables in a schema."""
        table1 = TableInfo("DB1", "SCH1", "TAB1", "TABLE", [])
        table2 = TableInfo("DB1", "SCH1", "TAB2", "TABLE", [])
        table3 = TableInfo("DB1", "SCH2", "TAB3", "TABLE", [])
        table4 = TableInfo("DB2", "SCH1", "TAB4", "TABLE", [])

        for table in [table1, table2, table3, table4]:
            cache.add_table(table)

        result = cache.get_tables_in_schema("DB1", "SCH1")
        assert len(result) == 2
        assert table1 in result
        assert table2 in result

    def test_search_tables(self, cache):
        """Test searching tables by name."""
        table1 = TableInfo("DB1", "SCH1", "USERS", "TABLE", [], comment="User data")
        table2 = TableInfo("DB1", "SCH1", "USER_LOGS", "TABLE", [])
        table3 = TableInfo("DB1", "SCH1", "PRODUCTS", "TABLE", [])

        for table in [table1, table2, table3]:
            cache.add_table(table)

        # Search in table names
        result = cache.search_tables("USER")
        assert len(result) == 2
        assert table1 in result
        assert table2 in result

        # Search in comments
        result = cache.search_tables("data")
        assert len(result) == 1
        assert table1 in result

        # Case insensitive search
        result = cache.search_tables("user")
        assert len(result) == 2

    def test_save_and_load_cache(self, cache):
        """Test saving and loading cache to/from disk."""
        # Add some data
        table = TableInfo(
            database="TEST_DB",
            schema="PUBLIC",
            table_name="USERS",
            table_type="TABLE",
            columns=[
                ColumnInfo("id", "NUMBER", False, 1),
                ColumnInfo("name", "VARCHAR", True, 2),
            ]
        )
        cache.add_table(table)
        cache.last_refresh = datetime.now()

        # Save cache
        cache.save()
        assert cache.cache_file.exists()

        # Create new cache instance and load
        cache2 = SchemaCache(cache_dir=cache.cache_dir)
        cache2.load()

        assert "TEST_DB.PUBLIC.USERS" in cache2.tables
        loaded_table = cache2.tables["TEST_DB.PUBLIC.USERS"]
        assert loaded_table.table_name == "USERS"
        assert len(loaded_table.columns) == 2
        assert "TEST_DB" in cache2.databases
        assert cache2.last_refresh is not None

    def test_load_nonexistent_cache(self, cache):
        """Test loading when cache file doesn't exist."""
        result = cache.load()
        assert result is False
        assert cache.tables == {}
        assert cache.databases == set()

    def test_clear_cache(self, cache):
        """Test clearing the cache."""
        # Add some data
        table = TableInfo("DB", "SCH", "TAB", "TABLE", [])
        cache.add_table(table)
        cache.last_refresh = datetime.now()

        # Clear cache
        cache.clear()

        assert cache.tables == {}
        assert cache.databases == set()
        assert cache.last_refresh is None

    def test_get_statistics(self, cache):
        """Test getting cache statistics."""
        # Add some tables
        table1 = TableInfo("DB1", "SCH1", "TAB1", "TABLE", [ColumnInfo("col1", "VARCHAR", True, 1)])
        table2 = TableInfo("DB1", "SCH2", "TAB2", "VIEW", [ColumnInfo("col1", "NUMBER", False, 1), ColumnInfo("col2", "VARCHAR", True, 2)])
        table3 = TableInfo("DB2", "SCH1", "TAB3", "TABLE", [])

        for table in [table1, table2, table3]:
            cache.add_table(table)

        cache.last_refresh = datetime.now()

        stats = cache.get_statistics()

        assert stats["total_tables"] == 3
        assert stats["total_columns"] == 3
        assert stats["total_databases"] == 2
        assert stats["is_expired"] is False
        assert stats["last_refresh"] is not None

    def test_save_checkpoint(self, cache):
        """Test saving a checkpoint."""
        checkpoint_data = {
            "database": "TEST_DB",
            "processed_count": 10,
            "total_count": 50
        }

        cache.save_checkpoint("test_checkpoint", checkpoint_data)

        checkpoint_file = cache.checkpoint_dir / "test_checkpoint.json"
        assert checkpoint_file.exists()

        with open(checkpoint_file) as f:
            loaded_data = json.load(f)
        assert loaded_data == checkpoint_data

    def test_load_checkpoint(self, cache):
        """Test loading a checkpoint."""
        checkpoint_data = {
            "database": "TEST_DB",
            "processed_count": 10
        }

        # Save checkpoint
        cache.save_checkpoint("test_checkpoint", checkpoint_data)

        # Load checkpoint
        loaded = cache.load_checkpoint("test_checkpoint")
        assert loaded == checkpoint_data

    def test_load_nonexistent_checkpoint(self, cache):
        """Test loading a non-existent checkpoint."""
        result = cache.load_checkpoint("nonexistent")
        assert result is None

    def test_clear_checkpoints(self, cache):
        """Test clearing all checkpoints."""
        # Create some checkpoint files
        cache.save_checkpoint("checkpoint1", {"data": 1})
        cache.save_checkpoint("checkpoint2", {"data": 2})

        # Verify files exist
        assert (cache.checkpoint_dir / "checkpoint1.json").exists()
        assert (cache.checkpoint_dir / "checkpoint2.json").exists()

        # Clear checkpoints
        cache.clear_checkpoints()

        # Verify files are removed
        assert not (cache.checkpoint_dir / "checkpoint1.json").exists()
        assert not (cache.checkpoint_dir / "checkpoint2.json").exists()

    def test_log_refresh_error(self, cache):
        """Test logging refresh errors."""
        error1 = {
            "database": "DB1",
            "error": "Connection failed",
            "timestamp": datetime.now().isoformat()
        }
        error2 = {
            "database": "DB2",
            "error": "Permission denied",
            "timestamp": datetime.now().isoformat()
        }

        cache.log_refresh_error(error1)
        cache.log_refresh_error(error2)

        errors = cache.get_refresh_errors()
        assert len(errors) == 2
        assert error1 in errors
        assert error2 in errors

    def test_clear_refresh_errors(self, cache):
        """Test clearing refresh errors."""
        error = {"error": "test error"}
        cache.log_refresh_error(error)

        # Verify error exists
        assert len(cache.get_refresh_errors()) == 1

        # Clear errors
        cache.clear_refresh_errors()

        # Verify errors are cleared
        assert len(cache.get_refresh_errors()) == 0

    def test_acquire_and_release_lock(self, cache):
        """Test acquiring and releasing the cache lock."""
        # Acquire lock
        acquired = cache.acquire_lock()
        assert acquired is True
        assert cache.refresh_in_progress is True

        # Try to acquire again (should fail)
        acquired_again = cache.acquire_lock()
        assert acquired_again is False

        # Release lock
        cache.release_lock()
        assert cache.refresh_in_progress is False

        # Should be able to acquire again
        acquired_after_release = cache.acquire_lock()
        assert acquired_after_release is True